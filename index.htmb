// ── Slider helpers ──────────────────────────────
function cltSlideTo(i){
  const slidesEl = document.getElementById('cltSlides');
  cltCur = (i + cltTotal) % cltTotal;
  slidesEl.style.transform = `translateX(-${cltCur*100}%)`;
  document.querySelectorAll('.clt-dot').forEach((d,j)=>d.classList.toggle('on', j===cltCur));
}
function cltSlideMove(dir){ cltSlideTo(cltCur + dir); }
function cltStartAuto(){
  if(cltTimer) clearInterval(cltTimer);
  if(cltTotal > 1) cltTimer = setInterval(()=>cltSlideMove(1), 4000);
}

// ── Build slider for a given club slug ──────────
function cltBuildSlider(slug){
  cltCur = 0;
  const slidesEl = document.getElementById('cltSlides');
  const navEl    = document.getElementById('cltSlideNav');

  // Get slides from DB map or fallback to static
  const cat  = cltClubs.find(c=>(c.slug||c.category_name.toLowerCase().replace(/\s+club/i,'').trim())===slug);
  const dbSlides = cat ? (cltSlideMap[cat.category_id]||[]) : [];

  let html = '';
  if(dbSlides.length){
    html = dbSlides.map(s=>{
      const bg = s.image_url
        ? `background-image:url(${s.image_url});background-size:cover;background-position:center`
        : (s.bg_gradient ? `background:${s.bg_gradient}` : 'background:linear-gradient(135deg,#1a2e47,#0d1b2a)');
      return `<div class="clt-slide">
        <div class="clt-slide-bg" style="${bg}"></div>
        <div class="clt-slide-overlay"></div>
        <div class="clt-slide-content">
          <div class="clt-slide-club">${cat.icon_emoji||''} ${cat.category_name}</div>
          <div class="clt-slide-title">${s.title||cat.category_name}</div>
          <div class="clt-slide-sub">${s.subtitle||''}</div>
        </div>
      </div>`;
    }).join('');
    cltTotal = dbSlides.length;
  } else {
    const statics = CLT_DEFAULT_SLIDES[slug] || [{title:'Welcome',sub:'',emoji:'●',grad:'linear-gradient(135deg,#1a2e47,#0d1b2a)'}];
    html = statics.map(s=>`<div class="clt-slide">
      <div class="clt-slide-bg" style="background:${s.grad};display:flex;align-items:center;justify-content:center">
        <span style="font-size:5rem;opacity:.25">${s.emoji}</span>
      </div>
      <div class="clt-slide-overlay"></div>
      <div class="clt-slide-content">
        <div class="clt-slide-club">${CLT_CLUBS_STATIC.find(c=>c.slug===slug)?.icon||''} ${CLT_CLUBS_STATIC.find(c=>c.slug===slug)?.name||slug}</div>
        <div class="clt-slide-title">${s.title}</div>
        <div class="clt-slide-sub">${s.sub}</div>
      </div>
    </div>`).join('');
    cltTotal = statics.length;
  }

  slidesEl.innerHTML = html;
  slidesEl.style.transform = 'translateX(0)';

  // Dots + arrows
  const dots = Array.from({length:cltTotal},(_,i)=>`<div class="clt-dot${i===0?' on':''}" onclick="cltSlideTo(${i})"></div>`).join('');
  navEl.innerHTML = `
    <div class="clt-arrow" onclick="cltSlideMove(-1)">←</div>
    ${dots}
    <div class="clt-arrow" onclick="cltSlideMove(1)">→</div>`;

  cltStartAuto();
}

// cltBuildMarketingCards — removed (no longer used)
function cltBuildMarketingCards(){}

// ── Build club tabs — always show all 5, disable unavailable ones ──
function cltBuildTabs(){
  const el = document.getElementById('cltTabs');
  // Active slugs for this region
  const activeSlugs = cltClubs.map(c => c.slug || c.category_name.toLowerCase().replace(/\s+club/i,'').trim());
  const firstActive = activeSlugs[0] || CLT_CLUBS_STATIC[0].slug;

  el.innerHTML = CLT_CLUBS_STATIC.map(c => {
    const isActive = activeSlugs.includes(c.slug);
    const isFirst  = c.slug === firstActive;
    return `<button class="clt-tab${isFirst?' on':''}"
      data-slug="${c.slug}"
      ${isActive ? `onclick="cltSelectClub('${c.slug}',this)"` : 'disabled title="Not available in this region"'}
      style="${!isActive?'opacity:.35;cursor:not-allowed;':''}"
    ><span class="clt-tab-icon">${c.icon}</span><span class="clt-tab-label">${c.name}</span></button>`;
  }).join('');
}

// ── Select a club tab ───────────────────────────
function cltSelectClub(slug, triggerEl){
  cltActiveSlug = slug;
  document.querySelectorAll('.clt-tab').forEach(t=>t.classList.toggle('on', t.dataset.slug===slug));
  cltBuildSlider(slug);
  cltOpenProducts(slug);
}

// ── Open product listing for a club ────────────
async function cltOpenProducts(slug){
  document.getElementById('prodListing').classList.add('on');

  cltActiveSlug = slug;
  document.querySelectorAll('.clt-tab').forEach(t=>t.classList.toggle('on', t.dataset.slug===slug));
  cltBuildSlider(slug);

  const staticClub = CLT_CLUBS_STATIC.find(c=>c.slug===slug);
  document.getElementById('prodIcon').textContent  = staticClub?.icon || '●';
  document.getElementById('prodTitle').textContent = staticClub?.name || slug;
  document.getElementById('prodSub').textContent   = 'Loading…';
  document.getElementById('prodGrid').innerHTML    = '<div class="prod-loading">Fetching products…</div>';

  try {
    const regionClubId = currentRegion.club_id;

    // Step 1: get category_id from product_categories WHERE slug = clicked slug
    // cltClubs already loaded for this region via loadClubsForRegion
    // Find the matching category by slug — correct club_id already filtered at load time
    const catRow = cltClubs.find(c => c.slug === slug);

    if(!catRow){
      document.getElementById('prodGrid').innerHTML =
        `<div class="prod-loading">⚠️ No category for slug: <strong>${slug}</strong><br>
         <small>Available: ${cltClubs.map(c=>c.slug).join(', ')}</small></div>`;
      return;
    }

    // Track active category for Add Product
    cltActiveCatId = catRow.category_id;
    document.getElementById('prodIcon').textContent  = catRow.icon_emoji || staticClub?.icon || '●';
    document.getElementById('prodTitle').textContent = catRow.category_name;
    document.getElementById('prodSub').textContent   = catRow.tagline || catRow.description || '';

    // Fetch products filtered by service_type if filter is set
    let q = _db.from('products')
      .select('product_id, product_name, service_type, uom, price, description')
      .eq('club_id',     regionClubId)
      .eq('category_id', catRow.category_id);
    if(prodFilter !== 'all') q = q.eq('service_type', prodFilter);
    const { data: prods, error: prodErr } = await q;

    if(prodErr) throw prodErr;

    if(!prods || !prods.length){
      document.getElementById('prodGrid').innerHTML =
        `<div class="prod-loading">⚠️ No products found.<br>
         <small>slug: ${slug} | category_id: ${catRow.category_id} | club_id: ${regionClubId}</small></div>`;
      return;
    }

    document.getElementById('prodGrid').innerHTML = prods.map(p => {
      const svc  = p.service_type || '';
      const isCommunity = svc === 'E';
      const isBuy       = svc === 'S' || svc === 'B';
      const pid  = p.product_id || '';
      const btnClass = isCommunity ? 'prod-enroll free-btn' : 'prod-enroll paid';
      const btnLabel = isCommunity ? '🤝 Join Community'
                     : isBuy       ? '🛒 Buy / Book'
                     :               'Enroll';
      const btnAction = isCommunity
        ? `onclick="handleEnroll('${pid}','join','${catRow.category_name}',this)"`
        : `onclick="handleEnroll('${pid}','buy','${catRow.category_name}',this)"`;
      const svcBadge = isCommunity
        ? `<div class="prod-badge" style="color:var(--accent);border-color:var(--accent)">Community</div>`
        : isBuy ? `<div class="prod-badge">Purchase</div>` : '';
      return `
      <div class="prod-card">
        <div class="prod-card-tag">${catRow.icon_emoji||''} ${catRow.category_name}</div>
        <div class="prod-card-name">${p.product_name||'Product'}</div>
        <div class="prod-card-desc">${p.description||''}</div>
        ${svcBadge ? `<div class="prod-card-badges">${svcBadge}</div>` : ''}
        <div class="prod-card-footer">
          <div class="prod-card-price free">${isCommunity ? 'Free' : p.price ? '₹'+Number(p.price).toLocaleString('en-IN') : 'Free'}</div>
          <button class="${btnClass}" ${btnAction} ${isBuy?'title="Payment flow coming soon"':''}>${btnLabel}</button>
        </div>
      </div>`;
    }).join('');

  } catch(e){
    console.error('Product load error:', e);
    document.getElementById('prodGrid').innerHTML =
      `<div class="prod-loading">❌ Error: ${e.message||e}</div>`;
  }
}

// ── Product filter state ──────────────────────
let prodFilter = 'E'; // default show community (E) only

function setFilter(f){
  prodFilter = f;
  document.getElementById('filterE').style.background   = f==='E'   ? 'var(--accent)' : 'var(--bg3)';
  document.getElementById('filterE').style.color        = f==='E'   ? 'var(--bg)'     : 'var(--text2)';
  document.getElementById('filterAll').style.background = f==='all' ? 'var(--accent)' : 'var(--bg3)';
  document.getElementById('filterAll').style.color      = f==='all' ? 'var(--bg)'     : 'var(--text2)';
  if(cltActiveSlug) cltOpenProducts(cltActiveSlug);
}
// handleEnroll defined above

// ── Back to marketing overview ──────────────────
function showMarketingView(){
  document.getElementById('prodListing').classList.remove('on');
  document.querySelectorAll('.clt-tab').forEach(t=>t.classList.remove('on'));
  const firstSlug = cltClubs.length
    ? (cltClubs[0].slug||cltClubs[0].category_name.toLowerCase().replace(/\s+club/i,'').trim())
    : CLT_CLUBS_STATIC[0].slug;
  cltBuildSlider(firstSlug);
  document.querySelectorAll('.clt-tab')[0]?.classList.add('on');
}

// ── Init the club landing section ───────────────
function initClubLanding(){
  cltActiveSlug = null;
  cltBuildTabs();

  // Default: select first active club, build slider and load its products
  const firstSlug = cltClubs.length
    ? (cltClubs[0].slug||cltClubs[0].category_name.toLowerCase().replace(/\s+club/i,'').trim())
    : CLT_CLUBS_STATIC[0].slug;
  cltActiveSlug = firstSlug;
  cltBuildSlider(firstSlug);
  cltOpenProducts(firstSlug);
}

// ══════════════════════════════════════════════
function renderClubs(categories, slidesMap, featuresMap){
  const tabsEl   = document.getElementById('clubTabs');
  const panelsEl = document.getElementById('clubPanels');
  const footerEl = document.getElementById('footerClubs');

  tabsEl.innerHTML = panelsEl.innerHTML = '';
  footerEl.innerHTML = '<h5>Our Clubs</h5>' +
    categories.map(c=>`<a href="#">${c.icon_emoji||''} ${c.category_name} — ${c.one_word||''}</a>`).join('');

  // strip — club names below marketing cards
  const stripEl = document.getElementById('strip');
  if(stripEl) stripEl.innerHTML = categories.map(c=>`<div class="strip-item">${c.icon_emoji||'◆'} ${c.category_name}</div>`).join('') + `<div class="strip-item">◆ Facilitating Regional Innovation</div>`;

  const ctaMap = {
    meetup:  ['View Schedule','Learn More'],
    infra:   ['Book a Desk','View Spaces'],
    study:   ['Find a Mentor','Browse Skills'],
    services:['Find an Expert','List Your Skills'],
    startup: ['Apply Now','Learn More']
  };

  categories.forEach((cat,idx)=>{
    const isFirst = idx===0;
    const slug    = cat.slug || cat.category_name.toLowerCase().replace(/\s+club/,'').trim();
    const slides  = slidesMap[cat.category_id]  || [];
    const feats   = featuresMap[cat.category_id] || [];

    // TAB
    const tab = document.createElement('button');
    tab.className = 'ctab'+(isFirst?' on':'');
    tab.innerHTML = `
      <div class="ctab-icon">${cat.icon_emoji||'●'}</div>
      <div class="ctab-word">${cat.one_word||''}</div>
      <div class="ctab-name">${cat.category_name.replace(/\s*Club/i,'')}</div>`;
    tab.onclick = ()=> switchClub(slug, tab);
    tabsEl.appendChild(tab);

    // SLIDER STATE
    SS[slug] = {cur:0, tot:Math.max(slides.length,1)};

    const slidesHTML = slides.length
      ? slides.map(s=>{
          const bgStyle = s.image_url
            ? `background-image:url(${s.image_url});background-size:cover;background-position:center`
            : (s.bg_gradient ? `background:${s.bg_gradient}` : 'background:linear-gradient(135deg,#1a2e47,#0d1b2a)');
          return `
          <div class="slide">
            <div class="slide-bg" style="${bgStyle};display:flex;align-items:center;justify-content:center">
              ${!s.image_url?`<span style="font-size:4rem">${s.bg_emoji||cat.icon_emoji||'●'}</span>`:''}
            </div>
            <div class="scap"><h4>${s.title||cat.category_name}</h4><p>${s.subtitle||''}</p></div>
          </div>`;}).join('')
      : `<div class="slide"><div class="slide-bg" style="background:linear-gradient(135deg,#1a2e47,#0d1b2a);display:flex;align-items:center;justify-content:center"><span style="font-size:4rem">${cat.icon_emoji||'●'}</span></div><div class="scap"><h4>${cat.category_name}</h4><p>${cat.tagline||''}</p></div></div>`;

    const dotsHTML = slides.map((_,i)=>
      `<div class="dot ${i===0?'on':''}" onclick="slideTo('${slug}',${i})"></div>`).join('');

    const featsHTML = feats.map(f=>`
      <div class="cfeat">
        <div class="fi">${f.icon_emoji||'•'}</div>
        <div class="ft"><strong>${f.title}</strong><span>${f.description||''}</span></div>
      </div>`).join('');

    const [cta1,cta2] = ctaMap[slug]||['Get Started','Learn More'];

    // PANEL
    const panel = document.createElement('div');
    panel.className = 'cpanel'+(isFirst?' on':'');
    panel.id = 'panel-'+slug;
    panel.innerHTML = `
      <div>
        <div class="strack"><div class="sslides" id="ss-${slug}">${slidesHTML}</div></div>
        <div class="sctrl">
          <button class="sbtn" onclick="slideMove('${slug}',-1)">←</button>
          <div class="sdots" id="dots-${slug}">${dotsHTML}</div>
          <button class="sbtn" onclick="slideMove('${slug}',1)">→</button>
        </div>
      </div>
      <div class="cinfo">
        <div class="cinfo-badge">${cat.icon_emoji||''} ${cat.category_name}</div>
        <h3>${cat.one_word||cat.category_name}.</h3>
        <div class="cinfo-tagline">${cat.tagline||''}</div>
        <p class="cinfo-desc">${cat.description||''}</p>
        <div class="cfeats">${featsHTML}</div>
        <div class="cbtns">
          <button class="bsm p">${cta1}</button>
          <button class="bsm g">${cta2}</button>
        </div>
      </div>`;
    panelsEl.appendChild(panel);

    // auto-advance
    setInterval(()=>{
      if(document.getElementById('panel-'+slug)?.classList.contains('on'))
        slideMove(slug,1);
    }, 4200);
  });
}

function switchClub(id,btn){
  document.querySelectorAll('.ctab').forEach(t=>t.classList.remove('on'));
  document.querySelectorAll('.cpanel').forEach(p=>p.classList.remove('on'));
  btn.classList.add('on');
  document.getElementById('panel-'+id)?.classList.add('on');
}

// ══════════════════════════════════════════════
//  SLIDERS
// ══════════════════════════════════════════════
function slideTo(id,i){
  if(!SS[id]) return;
  SS[id].cur = Math.max(0, Math.min(i, SS[id].tot-1));
  const el = document.getElementById('ss-'+id);
  if(el) el.style.transform = `translateX(-${SS[id].cur*100}%)`;
  document.querySelectorAll(`#dots-${id} .dot`).forEach((d,j)=>d.classList.toggle('on',j===SS[id].cur));
}
function slideMove(id,dir){
  if(!SS[id]) return;
  slideTo(id,(SS[id].cur+dir+SS[id].tot)%SS[id].tot);
}

// ══════════════════════════════════════════════
//  RENDER REGIONS section + "Partner" card
// ══════════════════════════════════════════════
function renderRegions(regions){
  const el = document.getElementById('regionCards');
  const all = [...regions, {
    club_id:'partner', club_name:'Your Region',
    flag_emoji:'🌐', status:'upcoming',
    tagline:'Partner with Us',
    description:'Interested in bringing CoworkClub to your region? Let\'s build it together.'
  }];
  el.innerHTML = all.map(r=>`
    <div class="rcard ${r.club_id===currentRegion?.club_id?'current':''}"
         data-club-id="${r.club_id}"
         onclick="${r.club_id!=='partner'?`selectRegion('${r.club_id}')`:''}" >
      <div class="rflag">${r.flag_emoji||'🌐'}</div>
      <div class="rname">${r.club_name}</div>
      <div class="rstatus ${r.status||'upcoming'}">
        ${r.status==='active'?'Active':r.status==='launching'?'Launching':r.tagline||'Coming Soon'}
      </div>
      <div class="rline"></div>
      <div class="rdesc">${r.description||r.tagline||''}</div>
    </div>`).join('');
}

// ══════════════════════════════════════════════
//  INIT
//  1. Load all regions
//  2. Pick default (is_default=true) or first active
//  3. Load that region's clubs
//  4. Build region selector dropdown
//  FUTURE: detect IP → filter regions by country
// ══════════════════════════════════════════════
async function init(){
  setP(15);
  try {
    // Load all active+launching regions
    allRegions = await sb('clubs', 'select=*&status=in.(active,launching)');
    setP(40);

    if(!allRegions.length) throw new Error('No active regions');

    // Pick default region
    // PHASE 1: use is_default flag
    // PHASE 2 (future): detect IP country → filter allRegions by country → pick first match
    currentRegion = allRegions.find(r=>r.is_default) || allRegions[0];

    // Build region dropdown
    buildRegionDropdown(allRegions);

    // Update region bar + nav button
    updateRegionUI();

    // Render regions section
    renderRegions(allRegions);

    setP(60);

    // Load clubs for default region
    await loadClubsForRegion(currentRegion.club_id);

    // Load delivery routes for this region
    await loadRoutes();

    setP(100);

  } catch(err){
    console.warn('Supabase error:', err);
    setP(100);
    // Graceful fallback
    document.getElementById('clubTabs').innerHTML =
      `<div style="padding:1rem 2rem;color:var(--text3);font-size:.85rem">
        ⚠️ Run the migration SQL in Supabase to populate data.
      </div>`;
    document.getElementById('regionCards').innerHTML =
      `<div class="rcard"><div class="rflag">🇮🇳</div><div class="rname">India</div><div class="rstatus active">Active</div><div class="rline"></div></div>
       <div class="rcard"><div class="rflag">🇦🇪</div><div class="rname">UAE</div><div class="rstatus launching">Launching</div><div class="rline"></div></div>
       <div class="rcard"><div class="rflag">🌐</div><div class="rname">Your Region</div><div class="rstatus upcoming">Partner with Us</div><div class="rline"></div></div>`;
    document.getElementById('btnName').textContent = 'Select Region';
    // Still show static club landing
    cltClubs = []; cltSlideMap = {};
    initClubLanding();
    // Try loading routes anyway
    loadRoutes();
  }
}

init();
</script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
// ══════════════════════════════════════════════
//  ROUTES — fetch, render grid, open map
// ══════════════════════════════════════════════
let _allRoutes    = [];
let _leafletMap   = null;
let _activeRouteId = null;

// Emoji cycle for route cards
const ROUTE_ICONS = ['🗺️','🛵','🚐','🏘️','🛤️','📍'];

async function loadRoutes(){
  try {
    // Filter routes for current region's club_id
    let q = _db.from('routes').select('*').eq('is_active', true);
    if(currentRegion?.club_id) q = q.eq('club_id', currentRegion.club_id);
    const { data, error } = await q.order('route_name');
    if(error) throw error;
    _allRoutes = data || [];
    renderRouteGrid(_allRoutes);
  } catch(e){
    document.getElementById('routeGrid').innerHTML =
      `<div style="grid-column:1/-1;padding:2rem;text-align:center;color:var(--text3);font-size:.85rem">
        ⚠️ Could not load routes: ${e.message}
      </div>`;
  }
}

function renderRouteGrid(routes){
  const el = document.getElementById('routeGrid');
  if(!routes.length){
    el.innerHTML = `<div style="padding:2.5rem;text-align:center;color:var(--text3);font-size:.85rem;grid-column:1/-1">
      No active routes in this region yet.
    </div>`;
    return;
  }
  el.innerHTML = routes.map((r, i) => `
    <div class="route-card" id="rc-${r.route_id}" onclick="openRouteMap('${r.route_id}')">
      <div class="rc-icon">${ROUTE_ICONS[i % ROUTE_ICONS.length]}</div>
      <div class="rc-name">${r.route_name}</div>
      <div class="rc-desc">${r.description || 'Hyperlocal delivery route'}</div>
      <div class="rc-meta">
        <span class="rc-badge">Active</span>
        <span class="rc-wpt-count" id="wc-${r.route_id}">Loading stops…</span>
      </div>
      <div class="rc-arrow">View Map →</div>
    </div>`).join('');

  // Fetch waypoint counts for each route
  routes.forEach(async r => {
    const { count } = await _db.from('route_waypoints')
      .select('*', { count:'exact', head:true })
      .eq('route_id', r.route_id);
    const el = document.getElementById(`wc-${r.route_id}`);
    if(el) el.textContent = `${count || 0} stop${count !== 1 ? 's' : ''}`;
  });
}

async function openRouteMap(routeId){
  _activeRouteId = routeId;
  const route = _allRoutes.find(r => r.route_id === routeId);
  if(!route) return;

  // Highlight selected card
  document.querySelectorAll('.route-card').forEach(c => c.classList.remove('selected'));
  document.getElementById(`rc-${routeId}`)?.classList.add('selected');

  // Show panel
  const panel = document.getElementById('routeMapPanel');
  panel.style.display = 'block';
  document.getElementById('rmpName').textContent = route.route_name;
  document.getElementById('rmpSub').textContent  = route.description || 'Loading waypoints…';
  document.getElementById('rmpMapLoading').style.display = 'flex';
  document.getElementById('rmpWptList').innerHTML = '<div style="color:var(--text3);font-size:.82rem">Loading stops…</div>';

  // Scroll to panel
  setTimeout(() => panel.scrollIntoView({ behavior:'smooth', block:'nearest' }), 100);

  // Fetch waypoints
  const { data: wpts, error } = await _db
    .from('route_waypoints')
    .select('*')
    .eq('route_id', routeId)
    .order('sequence');

  if(error || !wpts?.length){
    document.getElementById('rmpSub').textContent = 'No waypoints defined yet.';
    document.getElementById('rmpMapLoading').innerHTML =
      `<span style="font-size:2rem">📍</span>
       <div style="font-size:.82rem;color:var(--text2);margin-top:.5rem">No waypoints added to this route yet.</div>`;
    document.getElementById('rmpWptList').innerHTML =
      `<div style="color:var(--text3);font-size:.78rem">No stops defined.</div>`;
    return;
  }

  document.getElementById('rmpSub').textContent = `${wpts.length} stop${wpts.length!==1?'s':''} · Tap a stop to focus`;

  // Render waypoints list
  document.getElementById('rmpWptList').innerHTML = wpts.map((w, i) => `
    <div class="rmp-wpt-item" onclick="focusWaypoint(${w.lat},${w.lng},'${w.way_name}')" style="cursor:pointer">
      <div class="rmp-wpt-num">${w.sequence}</div>
      <div class="rmp-wpt-info">
        <div class="rmp-wpt-name">${w.way_name}</div>
        <div class="rmp-wpt-coord">${Number(w.lat).toFixed(5)}, ${Number(w.lng).toFixed(5)}</div>
      </div>
    </div>`).join('');

  // Build / update Leaflet map
  drawRouteMap(wpts, route.route_name);
}

// ── OSRM road-snapped routing ─────────────────
// Calls the public OSRM demo server with all waypoints in sequence,
// closes the loop back to stop #1, and draws the real road geometry.
// No API key required.
async function drawRouteMap(wpts, routeName){

  const latlngs = wpts.map(w => [parseFloat(w.lat), parseFloat(w.lng)]);
  const center  = latlngs[0] || [11.8745, 75.3704];

  // Destroy previous map instance
  if(_leafletMap){ _leafletMap.remove(); _leafletMap = null; }

  // Init Leaflet map
  _leafletMap = L.map('rmpMap', { zoomControl:true, scrollWheelZoom:true }).setView(center, 13);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution:'© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom:19
  }).addTo(_leafletMap);

  // Place numbered stop markers first (visible immediately)
  wpts.forEach(w => {
    const isFirst = w.sequence === 1;
    const icon = L.divIcon({
      html:`<div style="
        width:${isFirst?32:26}px;height:${isFirst?32:26}px;
        background:${isFirst?'#c9a84c':'#132236'};
        border:2.5px solid #c9a84c;border-radius:50%;
        display:flex;align-items:center;justify-content:center;
        font-size:${isFirst?.72:.6}rem;font-weight:800;
        color:${isFirst?'#0d1b2a':'#c9a84c'};
        box-shadow:0 2px 10px rgba(0,0,0,.5);
        font-family:'Outfit',sans-serif;">${w.sequence}</div>`,
      className:'', iconSize:[isFirst?32:26,isFirst?32:26],
      iconAnchor:[isFirst?16:13,isFirst?16:13], popupAnchor:[0,-16]
    });
    L.marker([parseFloat(w.lat), parseFloat(w.lng)], {icon})
      .addTo(_leafletMap)
      .bindPopup(`
        <div style="font-family:'Outfit',sans-serif;min-width:150px">
          <div style="font-size:.6rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#888;margin-bottom:3px">Stop ${w.sequence}</div>
          <div style="font-size:.9rem;font-weight:600;color:#111">${w.way_name}</div>
          <div style="font-size:.65rem;font-family:monospace;color:#999;margin-top:3px">${Number(w.lat).toFixed(5)}, ${Number(w.lng).toFixed(5)}</div>
        </div>`, {maxWidth:210});
  });

  // Fit to markers while road route loads
  if(latlngs.length > 1){
    _leafletMap.fitBounds(L.latLngBounds(latlngs), {padding:[40,40]});
  }

  // Hide loading overlay — markers are visible, route will appear on top
  document.getElementById('rmpMapLoading').style.display = 'none';
  setTimeout(() => _leafletMap.invalidateSize(), 150);

  // ── OSRM: build road route segment-by-segment ──
  // For a circular route we go: 1→2, 2→3, … N→1
  // Each segment is one OSRM call so we get accurate road geometry
  // between every consecutive pair of stops.
  const accentColor = '#c9a84c';
  const totalStops  = latlngs.length;

  if(totalStops < 2){
    // Single stop — nothing to route
    return;
  }

  // Show a subtle "routing…" notice on map
  const routingNotice = L.control({position:'bottomleft'});
  routingNotice.onAdd = () => {
    const d = L.DomUtil.create('div');
    d.innerHTML = `<div style="background:rgba(13,27,42,.85);color:#c9a84c;padding:.35rem .75rem;font-size:.7rem;font-family:'Outfit',sans-serif;border:1px solid rgba(201,168,76,.3)">
      🛣️ Loading road route…</div>`;
    return d;
  };
  routingNotice.addTo(_leafletMap);

  // Build segment pairs: [0→1, 1→2, …, N-1→0] (close the loop)
  const segments = [];
  for(let i = 0; i < totalStops; i++){
    segments.push([latlngs[i], latlngs[(i+1) % totalStops]]);
  }

  let successCount = 0;

  await Promise.all(segments.map(async ([from, to]) => {
    // OSRM expects coordinates as lng,lat (GeoJSON order)
    const coords = `${from[1]},${from[0]};${to[1]},${to[0]}`;
    const url = `https://router.project-osrm.org/route/v1/driving/${coords}?overview=full&geometries=geojson`;

    try {
      const res  = await fetch(url);
      const json = await res.json();
      if(json.code !== 'Ok' || !json.routes?.length) return;

      const roadCoords = json.routes[0].geometry.coordinates
        .map(([lng, lat]) => [lat, lng]); // flip back to [lat,lng] for Leaflet

      // Draw this road segment
      L.polyline(roadCoords, {
        color:   accentColor,
        weight:  4,
        opacity: 0.9,
        lineJoin:'round',
        lineCap: 'round'
      }).addTo(_leafletMap);

      successCount++;
    } catch(e){
      // Segment failed — fall back to straight line for this segment only
      L.polyline([from, to], {
        color:     accentColor,
        weight:    3,
        opacity:   0.5,
        dashArray: '6 6'  // dashed = "no road data, straight line"
      }).addTo(_leafletMap);
    }
  }));

  // Remove routing notice
  routingNotice.remove();

  // Add a small legend showing solid = road, dashed = no data
  if(successCount < segments.length){
    const legend = L.control({position:'bottomright'});
    legend.onAdd = () => {
      const d = L.DomUtil.create('div');
      d.innerHTML = `<div style="background:rgba(13,27,42,.85);color:#9aafbe;padding:.4rem .75rem;font-size:.65rem;font-family:'Outfit',sans-serif;border:1px solid rgba(255,255,255,.08);line-height:1.7">
        <span style="color:#c9a84c">━━</span> Road route<br>
        <span style="color:#c9a84c">╌╌</span> No road data (straight line)
      </div>`;
      return d;
    };
    legend.addTo(_leafletMap);
  }
}

function focusWaypoint(lat, lng, name){
  if(!_leafletMap) return;
  _leafletMap.setView([parseFloat(lat), parseFloat(lng)], 16, { animate:true });
}

function closeRouteMap(){
  document.getElementById('routeMapPanel').style.display = 'none';
  document.querySelectorAll('.route-card').forEach(c => c.classList.remove('selected'));
  _activeRouteId = null;
  if(_leafletMap){ _leafletMap.remove(); _leafletMap = null; }
}
</script>
</body>
</html>

let cltSlideMap   = {};   // category_id → slides[]
let cltActiveSlug = null; // currently selected club slug
let cltCur        = 0;    // current slide index
let cltTotal      = 1;    // total slides
let cltTimer      = null; // auto-advance timer

const CLT_CLUBS_STATIC = [
  { slug:'meetup',   name:'Meetup Club',   icon:'🤝', pitch:'Community events, networking & local meetups', color:'#c9a84c' },

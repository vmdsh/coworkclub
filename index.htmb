  { slug:'startup',  name:'Startup Club',  icon:'🚀', pitch:'Launchpad for regional founders & ideas',    color:'#9a4cc9' },
];

// Default slides per club (concept placeholders — replace with DB slides when available)
const CLT_DEFAULT_SLIDES = {
  meetup:[
    {title:'Community First',       sub:'Connect with driven people in your region', emoji:'🤝', grad:'linear-gradient(135deg,#1a2e20,#0d2b1a)'},
    {title:'Monthly Meetups',       sub:'Real conversations. Real connections.',      emoji:'🎤', grad:'linear-gradient(135deg,#2e1a0d,#1a0d0d)'},
  ],
  infra:[
    {title:'Your Workspace Awaits', sub:'Hot desks, cabins & meeting rooms on demand', emoji:'🏢', grad:'linear-gradient(135deg,#0d1b2e,#1a2e47)'},
    {title:'Book by the Hour',      sub:'Flexible, affordable, professional',          emoji:'⏱️', grad:'linear-gradient(135deg,#1a1b2e,#0d0d1b)'},
  ],
  study:[
    {title:'Learn in 2 Hours',      sub:'Micro-skill sessions with a local mentor',   emoji:'📚', grad:'linear-gradient(135deg,#1a2e1a,#0d1b0d)'},
    {title:'AI & Digital Skills',   sub:'Stay relevant. Upskill at your own pace.',   emoji:'🤖', grad:'linear-gradient(135deg,#2e2a0d,#1b1a0d)'},
  ],
  services:[
    {title:'Get It Done For You',   sub:'Assign tasks to verified local experts',     emoji:'⚙️', grad:'linear-gradient(135deg,#2e0d0d,#1b0d0d)'},
    {title:'Local. Fast. Reliable.',sub:'No offshore. Real people. Your region.',      emoji:'🙌', grad:'linear-gradient(135deg,#1a0d2e,#0d0d1b)'},
  ],
  startup:[
    {title:'Launch Here',           sub:'Mentorship, co-founders & funding support',  emoji:'🚀', grad:'linear-gradient(135deg,#1a0d2e,#2e1a0d)'},

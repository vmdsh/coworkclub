<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script>
// ══════════════════════════════════════════════
//  CONFIG — Supabase JS Client
// ══════════════════════════════════════════════
const SB_URL  = 'https://czacuvklmuzvtzkvazhc.supabase.co';
const SB_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImN6YWN1dmtsbXV6dnR6a3ZhemhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM4OTkzOTMsImV4cCI6MjA4OTQ3NTM5M30.PheGFbsV1gTbih7zZmXuFgFQFtnEfIDKwxyE_eqYSnM';

const _db = window.supabase.createClient(SB_URL, SB_ANON);

// Unified query helper using Supabase JS client
async function sb(table, params='') {
  let q = _db.from(table).select('*');
  params.split('&').filter(Boolean).forEach(p => {
    const eqIdx = p.indexOf('=');
    if(eqIdx === -1) return;
    const key = p.slice(0, eqIdx);
    const val = p.slice(eqIdx + 1);
    if(key === 'order') {
      q = q.order(val, {ascending: true});
    } else if(key === 'select') {
      // already select(*)
    } else if(val.startsWith('eq.')) {
      const v = val.slice(3);
      q = q.eq(key, v === 'true' ? true : v === 'false' ? false : v);
    } else if(val.startsWith('in.(') && val.endsWith(')')) {
      q = q.in(key, val.slice(4,-1).split(','));
    } else if(val === 'not.is.null') {
      q = q.not(key, 'is', null);
    } else if(val === 'is.null') {
      q = q.is(key, null);
    }
  });
  const {data, error} = await q;
  if(error) throw new Error(`${table}: ${error.message}`);
  return data || [];
}

// ══════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════
let allRegions    = [];
let currentRegion = null;
let currentUser   = null;   // logged-in Supabase user
let cltActiveCatId = null;  // category_id of active club tab
const SS = {};

// ══════════════════════════════════════════════
//  DEBUG BREAKPOINT HELPER
//  Shows SQL query in msgElId, waits for user
//  to click Continue before proceeding
// ══════════════════════════════════════════════
function debugBreakpoint(msgElId, sql){
  return new Promise(resolve => {
    const el = document.getElementById(msgElId);
    el.className = 'modal-msg';
    el.innerHTML = `
      <div style="background:var(--bg3);border:1px solid var(--accent);padding:.75rem;text-align:left;margin-bottom:.5rem">
        <div style="font-size:.65rem;font-weight:700;color:var(--accent);letter-spacing:.08em;margin-bottom:.4rem">🔍 DEBUG — SQL QUERY</div>
        <pre style="font-size:.68rem;color:var(--text);white-space:pre-wrap;word-break:break-all;margin:0;line-height:1.6;font-family:monospace">${sql}</pre>
      </div>
      <button onclick="document.getElementById('${msgElId}').dataset.go='1'"
        style="background:var(--accent);color:var(--bg);border:none;padding:.4rem 1.2rem;
               font-family:'Outfit',sans-serif;font-size:.75rem;font-weight:700;
               cursor:pointer;letter-spacing:.06em;width:100%">
        ▶ Continue Execution
      </button>`;
    // Poll for button click
    const check = setInterval(()=>{
      if(el.dataset.go === '1'){
        clearInterval(check);
        delete el.dataset.go;
        el.innerHTML = '';
        resolve();
      }
    }, 100);
  });
}

// ══════════════════════════════════════════════
//  AUTH — CUSTOM (users table, no Supabase Auth)
// ══════════════════════════════════════════════
function updateNavAuth(user){
  currentUser = user;
  const btn    = document.getElementById('navAuthBtn');
  const userEl = document.getElementById('navUser');
  const nameEl = document.getElementById('navUserName');
  const addBtn = document.getElementById('addProdBtn');
  if(user){
    btn.style.display    = 'none';
    userEl.style.display = 'flex';
    nameEl.textContent   = user.name || user.email.split('@')[0];
    if(addBtn) addBtn.style.display = 'inline-block';
  } else {
    btn.style.display    = 'inline-block';
    userEl.style.display = 'none';
    if(addBtn) addBtn.style.display = 'none';
  }
}

function openAuthModal(){ document.getElementById('authModal').classList.add('open') }
function closeAuthModal(){ document.getElementById('authModal').classList.remove('open') }

function switchAuthTab(tab){
  document.getElementById('formSignin').style.display = tab==='signin'?'':'none';
  document.getElementById('formSignup').style.display = tab==='signup'?'':'none';
  document.getElementById('tabSignin').classList.toggle('on', tab==='signin');
  document.getElementById('tabSignup').classList.toggle('on', tab==='signup');
  document.getElementById('siMsg').textContent = '';
  document.getElementById('suMsg').textContent = '';
}

// ── Sign In — SELECT from users table ────────
async function doSignIn(){
  const btn   = document.getElementById('siBtn');
  const msg   = document.getElementById('siMsg');
  const email = document.getElementById('siEmail').value.trim();
  const pass  = document.getElementById('siPass').value;
  if(!email||!pass){ msg.textContent='Please fill in all fields'; msg.className='modal-msg err'; return; }
  btn.disabled = true; btn.textContent = 'Signing in…';
  try {
    const { data, error } = await _db
      .from('users')
      .select('*')
      .eq('email', email)
      .eq('password', pass)
      .limit(1);
    if(error) throw error;
    if(!data || !data.length){
      msg.textContent = 'Invalid email or password'; msg.className='modal-msg err';
      btn.disabled = false; btn.textContent = 'Sign In'; return;
    }
    const user = data[0];
    localStorage.setItem('cwc_user', JSON.stringify(user));
    updateNavAuth(user);
    msg.textContent = `✓ Welcome back, ${user.name}!`; msg.className='modal-msg ok';
    btn.disabled = false; btn.textContent = 'Sign In';
    setTimeout(closeAuthModal, 800);
  } catch(e){
    msg.textContent = e.message; msg.className='modal-msg err';
    btn.disabled = false; btn.textContent = 'Sign In';
  }
}

// ── Sign Up — INSERT into users table ────────
async function doSignUp(){
  const btn   = document.getElementById('suBtn');
  const msg   = document.getElementById('suMsg');
  const name  = document.getElementById('suName').value.trim();
  const email = document.getElementById('suEmail').value.trim();
  const pass  = document.getElementById('suPass').value;
  if(!name||!email||!pass){ msg.textContent='Please fill in all fields'; msg.className='modal-msg err'; return; }
  if(pass.length < 6){ msg.textContent='Password must be at least 6 characters'; msg.className='modal-msg err'; return; }
  btn.disabled = true; btn.textContent = 'Creating account…';
  try {
    // Check if email already exists
    const { data: existing } = await _db.from('users').select('user_id').eq('email', email).limit(1);
    if(existing && existing.length){
      msg.textContent = 'Email already registered. Please sign in.'; msg.className='modal-msg err';
      btn.disabled = false; btn.textContent = 'Create Account'; return;
    }
    // INSERT INTO users (club_id, email, password, name, role)
    const { data, error } = await _db.from('users').insert({
      club_id:  currentRegion?.club_id || null,
      email:    email,
      password: pass,
      name:     name,
      role:     'member'
    }).select().single();
    if(error) throw error;
    localStorage.setItem('cwc_user', JSON.stringify(data));
    updateNavAuth(data);
    msg.textContent = `✓ Welcome, ${data.name}! Account created.`; msg.className='modal-msg ok';
    btn.disabled = false; btn.textContent = 'Create Account';
    setTimeout(closeAuthModal, 1000);
  } catch(e){
    msg.textContent = e.message; msg.className='modal-msg err';
    btn.disabled = false; btn.textContent = 'Create Account';
  }
}

// ── Sign Out ──────────────────────────────────
function signOut(){
  localStorage.removeItem('cwc_user');
  updateNavAuth(null);
}

// ── Restore session from localStorage ─────────
const _savedUser = localStorage.getItem('cwc_user');
if(_savedUser){ try{ updateNavAuth(JSON.parse(_savedUser)); }catch(e){ localStorage.removeItem('cwc_user'); } }

// ══════════════════════════════════════════════
//  ENROLL HANDLER — requires login
// ══════════════════════════════════════════════
async function handleEnroll(productId, type, clubName, btn){
  if(!currentUser){ openAuthModal(); return; }
  if(type === 'buy'){
    alert('🛒 Purchase flow coming soon!\n\n' + clubName);
    return;
  }
  btn.disabled = true; btn.textContent = 'Joining…';
  try {
    const { error } = await _db.from('product_users').insert({
      product_id: productId,
      user_id:    currentUser.user_id
    });
    if(error) throw error;
    btn.textContent   = '✓ Joined!';
    btn.style.opacity = '.6';
    btn.disabled      = true;
  } catch(e){
    btn.disabled     = false;
    btn.textContent  = '🤝 Join Community';
    alert('Error: ' + e.message);
  }
}

// ══════════════════════════════════════════════
//  ADD PRODUCT MODAL
// ══════════════════════════════════════════════
function openAddProduct(){
  if(!currentUser){ openAuthModal(); return; }
  const catRow = cltClubs.find(c => c.slug === cltActiveSlug);
  document.getElementById('apCategory').value  = catRow ? catRow.category_name : (cltActiveSlug || '');
  document.getElementById('apName').value      = '';
  document.getElementById('apDesc').value      = '';
  document.getElementById('apMsg').textContent = '';
  document.getElementById('addProdModal').classList.add('open');
}
function closeAddProduct(){ document.getElementById('addProdModal').classList.remove('open') }

async function doAddProduct(){
  if(!currentUser){ openAuthModal(); return; }
  const btn  = document.getElementById('apBtn');
  const msg  = document.getElementById('apMsg');
  const name = document.getElementById('apName').value.trim();
  const desc = document.getElementById('apDesc').value.trim();

  if(!name){ msg.textContent='Community name is required'; msg.className='modal-msg err'; return; }

  const catRow = cltClubs.find(c => c.slug === cltActiveSlug);
  if(!catRow){ msg.textContent='No active club selected'; msg.className='modal-msg err'; return; }

  btn.disabled = true; btn.textContent = 'Creating…';
  try {
    // INSERT INTO products — service_type='E' hardcoded (community enrollment)
    const { data: prod, error: prodErr } = await _db.from('products').insert({
      product_name:  name,
      description:   desc,
      service_type:  'E',
      category_id:   catRow.category_id,
      club_id:       currentRegion.club_id,
      created_by:    currentUser.user_id
    }).select().single();

    if(prodErr) throw prodErr;

    // INSERT INTO product_users — creator is admin
    const { error: puErr } = await _db.from('product_users').insert({
      product_id: prod.product_id || prod.id,
      user_id:    currentUser.user_id,
      is_admin:   true
    });
    if(puErr) console.warn('product_users:', puErr.message);

    msg.textContent = '✓ Community created!'; msg.className='modal-msg ok';
    btn.disabled = false; btn.textContent = 'Create Community';
    setTimeout(()=>{ closeAddProduct(); cltOpenProducts(cltActiveSlug); }, 900);

  } catch(e){
    msg.textContent = 'Error: ' + e.message; msg.className='modal-msg err';
    btn.disabled = false; btn.textContent = 'Create Community';
  }
}

// ══════════════════════════════════════════════
//  PROGRESS BAR
// ══════════════════════════════════════════════
function setP(p){
  const b = document.getElementById('lbar');
  b.style.width = p+'%';
  if(p>=100) setTimeout(()=>{ b.style.opacity='0'; },400);
  else b.style.opacity='1';
}

// ══════════════════════════════════════════════
//  THEME
// ══════════════════════════════════════════════
function setTheme(t,btn){
  document.body.setAttribute('data-theme',t);
  document.querySelectorAll('.tbtn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
}

// ══════════════════════════════════════════════
//  REGION DROPDOWN
// ══════════════════════════════════════════════
function toggleRegionDropdown(){
  const btn = document.getElementById('regionBtn');
  const dd  = document.getElementById('regionDropdown');
  const open = dd.classList.toggle('open');
  btn.classList.toggle('open', open);
  if(open){
    // close on outside click
    setTimeout(()=>{
      document.addEventListener('click', closeDropdownOutside, {once:true});
    },10);
  }
}
function closeDropdownOutside(e){
  const sel = document.getElementById('regionSelector');
  if(!sel.contains(e.target)){
    document.getElementById('regionDropdown').classList.remove('open');
    document.getElementById('regionBtn').classList.remove('open');
  }
}

function buildRegionDropdown(regions){
  const dd = document.getElementById('regionDropdown');
  const notice = `<div class="ip-notice">Clubs shown vary by region · IP detection coming soon</div>`;
  dd.innerHTML = regions.map(r => `
    <div class="region-option ${r.club_id===currentRegion?.club_id?'active':''}"
         onclick="selectRegion('${r.club_id}')">
      <span class="ro-flag">${r.flag_emoji||'🌐'}</span>
      <div class="ro-info">
        <div class="ro-name">${r.club_name}</div>
        <div class="ro-status ${r.status}">${r.status==='active'?'Active':r.status==='launching'?'Launching':'Upcoming'}</div>
      </div>
      <span class="ro-check">✓</span>
    </div>`).join('') + notice;
}

function selectRegion(clubId){
  const region = allRegions.find(r => r.club_id === clubId);
  if(!region || region.club_id === currentRegion?.club_id) {
    document.getElementById('regionDropdown').classList.remove('open');
    document.getElementById('regionBtn').classList.remove('open');
    return;
  }
  currentRegion = region;
  document.getElementById('regionDropdown').classList.remove('open');
  document.getElementById('regionBtn').classList.remove('open');
  updateRegionUI();
  loadClubsForRegion(clubId);
  // Reload routes for new region
  closeRouteMap();
  loadRoutes();
  // highlight in regions section
  document.querySelectorAll('.rcard').forEach(c=>{
    c.classList.toggle('current', c.dataset.clubId === clubId);
  });
}

function updateRegionUI(){
  if(!currentRegion) return;
  // nav button
  document.getElementById('btnFlag').textContent = currentRegion.flag_emoji||'🌐';
  document.getElementById('btnName').textContent  = currentRegion.club_name;
  // region bar
  document.getElementById('rbFlag').textContent   = currentRegion.flag_emoji||'🌐';
  document.getElementById('rbName').textContent   = currentRegion.club_name;
  document.getElementById('rbStatus').textContent = currentRegion.status==='active'?'Active':currentRegion.status==='launching'?'Launching':'Upcoming';
  document.getElementById('rbStatus').className   = `rb-status ${currentRegion.status}`;
  // rebuild dropdown active state
  buildRegionDropdown(allRegions);
  // region cards highlight
  document.querySelectorAll('.rcard').forEach(c=>{
    c.classList.toggle('current', c.dataset.clubId === currentRegion.club_id);
  });
}

// ══════════════════════════════════════════════
//  LOAD CLUBS FOR A REGION
// ══════════════════════════════════════════════
async function loadClubsForRegion(clubId){
  // animate out
  const inner = document.getElementById('clubsInner');
  if(inner) inner.classList.add('switching');

  // fetch categories for THIS region only
  // Step 1: fetch categories for THIS region only
  const categories = await sb('product_categories',
    `club_id=eq.${clubId}&is_predefined=eq.true&order=sort_order`);

  // Step 2: get only the category_ids for this region
  const catIds = categories.map(c => c.category_id);

  // Step 3: fetch slides + features filtered to these category_ids only
  // Using Supabase JS client directly for 'in' filter on fetched ids
  const [slidesRes, featuresRes] = await Promise.all([
    _db.from('product_category_images')
       .select('*')
       .in('category_id', catIds)
       .eq('is_active', true)
       .order('sort_order'),
    _db.from('category_features')
       .select('*')
       .in('category_id', catIds)
       .order('sort_order')
  ]);

  const slides   = slidesRes.data   || [];
  const features = featuresRes.data || [];

  // group slides + features by category_id
  const slidesMap={}, featuresMap={};
  slides.forEach(s=>{ if(!slidesMap[s.category_id]) slidesMap[s.category_id]=[]; slidesMap[s.category_id].push(s); });
  features.forEach(f=>{ if(!featuresMap[f.category_id]) featuresMap[f.category_id]=[]; featuresMap[f.category_id].push(f); });

  // update clubs count in bar
  document.getElementById('rbCount').textContent = `· ${categories.length} club${categories.length!==1?'s':''} available`;
  const _ey=document.getElementById('clubsEyebrow'); if(_ey) _ey.textContent = `Clubs Available in ${currentRegion?.club_name||'Your Region'}`;

  // animate in
  setTimeout(()=>{
    renderClubs(categories, slidesMap, featuresMap);
    if(inner) inner.classList.remove('switching');
    // populate club landing section
    cltClubs    = categories;
    cltSlideMap = slidesMap;
    initClubLanding();
  }, 250);
}


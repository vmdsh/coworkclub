<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aryaprabha CoworkClub — Get It Done When You Need It</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}

/* ── THEMES ── */
:root{
  --bg:#0d1b2a;--bg2:#132236;--bg3:#1a2e47;--surface:#1e3652;
  --border:rgba(255,255,255,0.08);
  --accent:#c9a84c;--accent2:#e8c96b;
  --text:#f0ead8;--text2:#9aafbe;--text3:#5a7488;
  --nav-bg:rgba(13,27,42,0.96);
  --pill-bg:rgba(201,168,76,0.12);--pill-text:#c9a84c;
  --tab-act:rgba(201,168,76,0.13);
  --hero-grad:linear-gradient(135deg,#0d1b2a 0%,#1a2e47 60%,#0d1b2a 100%);
}
[data-theme="fresh"]{
  --bg:#f7faf9;--bg2:#eef4f1;--bg3:#e3ede8;--surface:#fff;
  --border:rgba(0,0,0,0.08);--accent:#1a7a5e;--accent2:#2da882;
  --text:#0d2b22;--text2:#4a7060;--text3:#8aaa9a;
  --nav-bg:rgba(247,250,249,0.96);
  --pill-bg:rgba(26,122,94,0.1);--pill-text:#1a7a5e;
  --tab-act:rgba(26,122,94,0.08);
  --hero-grad:linear-gradient(135deg,#e3ede8 0%,#f7faf9 60%,#d4e8e0 100%);
}
[data-theme="bold"]{
  --bg:#080808;--bg2:#101010;--bg3:#181818;--surface:#1c1c1c;
  --border:rgba(255,255,255,0.06);--accent:#e63946;--accent2:#ff6b74;
  --text:#f8f8f8;--text2:#888;--text3:#444;
  --nav-bg:rgba(8,8,8,0.97);
  --pill-bg:rgba(230,57,70,0.1);--pill-text:#e63946;
  --tab-act:rgba(230,57,70,0.08);
  --hero-grad:linear-gradient(135deg,#080808 0%,#181818 50%,#080808 100%);
}
body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--text);line-height:1.6;overflow-x:hidden;transition:background .4s,color .4s}

/* ── LOADING BAR ── */
.lbar{height:2px;background:var(--accent);width:0;transition:width .3s;position:fixed;top:0;left:0;z-index:999}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  background:var(--nav-bg);backdrop-filter:blur(14px);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 4rem;height:66px;transition:background .4s;
}
.nav-brand{display:flex;align-items:center;gap:11px;text-decoration:none}
.nav-logo{width:36px;height:36px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-weight:900;font-size:1.1rem;color:var(--bg);flex-shrink:0}
.nav-name{font-family:'Playfair Display',serif;font-size:.97rem;font-weight:700;color:var(--text);line-height:1.1}
.nav-sub{font-size:.6rem;font-weight:600;color:var(--accent);letter-spacing:.12em;text-transform:uppercase}
/* ── NAV LINKS as buttons ── */
.nav-links{display:flex;gap:.5rem;align-items:center}
.nav-links a{
  text-decoration:none;color:var(--text2);font-size:.75rem;font-weight:500;
  padding:.38rem .9rem;border:1px solid var(--border);
  transition:color .2s,border-color .2s,background .2s;
  white-space:nowrap;
}
.nav-links a:hover{color:var(--text);border-color:var(--accent);background:var(--tab-act)}
.nav-links a.active{color:var(--accent);border-color:var(--accent);background:var(--tab-act)}
.nav-links a.highlight{
  color:var(--bg);background:var(--accent);border-color:var(--accent);font-weight:600;
}
.nav-links a.highlight:hover{opacity:.85}

/* ── REGION SELECTOR (the key new component) ── */
.region-selector{
  position:relative;display:flex;align-items:center;
}
.region-btn{
  display:flex;align-items:center;gap:7px;
  background:var(--bg3);border:1px solid var(--border);
  color:var(--text);padding:.38rem .9rem;
  font-family:'Outfit',sans-serif;font-size:.78rem;font-weight:500;
  cursor:pointer;transition:border-color .2s,background .2s;
  white-space:nowrap;
}
.region-btn:hover{border-color:var(--accent)}
.region-btn .rflag{font-size:.9rem}
.region-btn .rname{max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.region-btn .chevron{
  font-size:.6rem;color:var(--text3);
  transition:transform .2s;margin-left:2px;
}
.region-btn.open .chevron{transform:rotate(180deg)}

/* dropdown */
.region-dropdown{
  position:absolute;top:calc(100% + 6px);left:0;
  background:var(--bg2);border:1px solid var(--border);
  min-width:240px;z-index:300;
  box-shadow:0 8px 24px rgba(0,0,0,.3);
  display:none;
}
.region-dropdown.open{display:block}
.region-option{
  display:flex;align-items:center;gap:10px;
  padding:.75rem 1rem;cursor:pointer;
  font-size:.82rem;transition:background .15s;
  border-bottom:1px solid var(--border);
}
.region-option:last-child{border-bottom:none}
.region-option:hover{background:var(--bg3)}
.region-option.active{background:var(--tab-act)}
.region-option.active .ro-name{color:var(--accent)}
.ro-flag{font-size:1rem;flex-shrink:0}
.ro-info{flex:1}
.ro-name{font-weight:500;color:var(--text)}
.ro-status{
  font-size:.62rem;font-weight:600;letter-spacing:.08em;
  text-transform:uppercase;margin-top:1px;
}
.ro-status.active{color:var(--accent)}
.ro-status.launching{color:var(--accent2)}
.ro-status.upcoming{color:var(--text3)}
.ro-check{color:var(--accent);font-size:.8rem;opacity:0}
.region-option.active .ro-check{opacity:1}

/* IP notice */
.ip-notice{
  padding:.6rem 1rem;
  font-size:.68rem;color:var(--text3);
  border-top:1px solid var(--border);
  display:flex;align-items:center;gap:6px;
}
.ip-notice::before{content:'📍';font-size:.75rem}

.nav-right{display:flex;align-items:center;gap:12px}
.theme-switcher{display:flex;gap:5px}
.tbtn{width:20px;height:20px;border-radius:50%;border:2px solid transparent;cursor:pointer;transition:transform .2s,border-color .2s}
.tbtn:hover{transform:scale(1.2)}
.tbtn.on{border-color:var(--text)}
.tbtn[data-t="dark"] {background:linear-gradient(135deg,#0d1b2a,#c9a84c)}
.tbtn[data-t="fresh"]{background:linear-gradient(135deg,#f7faf9,#1a7a5e)}
.tbtn[data-t="bold"] {background:linear-gradient(135deg,#080808,#e63946)}
.nav-cta{background:var(--accent);color:var(--bg);border:none;padding:.52rem 1.3rem;font-family:'Outfit',sans-serif;font-size:.78rem;font-weight:600;cursor:pointer;letter-spacing:.06em;text-transform:uppercase;transition:opacity .2s,transform .15s}
.nav-cta:hover{opacity:.85;transform:translateY(-1px)}

/* ── HERO ── */
.hero{min-height:60vh;background:var(--hero-grad);display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:5rem 4rem;position:relative;overflow:hidden}
.hero-grid{position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:56px 56px}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--pill-bg);border:1px solid var(--accent);color:var(--accent);font-size:.68rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;padding:.32rem .9rem;margin-bottom:1.8rem}
.hero-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--accent);animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.5)}}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(2.8rem,6vw,5.4rem);font-weight:900;line-height:1.0;letter-spacing:-.03em;margin-bottom:.75rem;max-width:860px}
.hero h1 .ac{color:var(--accent)}
.hero h1 .it{font-style:italic}
.hero-hook{font-size:clamp(1rem,2vw,1.35rem);color:var(--text2);font-weight:300;max-width:600px;margin:0 auto 1rem;line-height:1.65}
.hero-hook strong{color:var(--text);font-weight:500}
.dual-mode{display:inline-flex;border:1px solid var(--border);overflow:hidden;margin:1.2rem 0 2rem}
.dm-half{padding:.55rem 1.4rem;font-size:.82rem;font-weight:500;letter-spacing:.04em;display:flex;align-items:center;gap:7px}
.dm-half:first-child{background:var(--pill-bg);color:var(--accent);border-right:1px solid var(--border)}
.dm-half:last-child{color:var(--text2)}
.dm-or{padding:.55rem .5rem;font-size:.72rem;font-weight:700;color:var(--text3);background:var(--bg2);border-left:1px solid var(--border);border-right:1px solid var(--border);display:flex;align-items:center}
.hero-actions{display:flex;gap:.9rem;justify-content:center}
.btn-p{background:var(--accent);color:var(--bg);border:none;padding:.85rem 2rem;font-family:'Outfit',sans-serif;font-size:.85rem;font-weight:600;cursor:pointer;letter-spacing:.06em;text-transform:uppercase;transition:opacity .2s,transform .15s}
.btn-p:hover{opacity:.86;transform:translateY(-2px)}
.btn-o{background:transparent;color:var(--text);border:1px solid var(--border);padding:.85rem 2rem;font-family:'Outfit',sans-serif;font-size:.85rem;font-weight:500;cursor:pointer;transition:border-color .2s,color .2s}
.btn-o:hover{border-color:var(--accent);color:var(--accent)}
.scroll-hint{position:absolute;bottom:2.2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:5px;color:var(--text3);font-size:.68rem;letter-spacing:.1em;text-transform:uppercase}
.scroll-hint::after{content:'';width:1px;height:36px;background:linear-gradient(to bottom,var(--accent),transparent);animation:sl 1.6s ease-in-out infinite}
@keyframes sl{0%{opacity:0;transform:scaleY(0);transform-origin:top}50%{opacity:1;transform:scaleY(1)}100%{opacity:0}}

/* ── STRIP ── */
.strip{background:var(--accent);padding:1.1rem 4rem;display:flex;align-items:center;justify-content:center;gap:2.5rem;flex-wrap:wrap}
.strip-item{font-size:.7rem;font-weight:700;color:var(--bg);letter-spacing:.1em;text-transform:uppercase;display:flex;align-items:center;gap:.4rem}

/* ── REGION CONTEXT BAR ── */
.region-bar{
  background:var(--bg2);border-bottom:1px solid var(--border);
  padding:.75rem 4rem;
  display:flex;align-items:center;justify-content:space-between;
  transition:background .4s;
}
.rb-left{display:flex;align-items:center;gap:10px;font-size:.82rem;color:var(--text2)}
.rb-flag{font-size:1.1rem}
.rb-name{font-weight:600;color:var(--text)}
.rb-status{
  font-size:.62rem;font-weight:700;letter-spacing:.08em;
  text-transform:uppercase;
  background:var(--pill-bg);color:var(--pill-text);
  border:1px solid var(--accent);
  padding:.18rem .55rem;
}
.rb-clubs-count{font-size:.78rem;color:var(--text3)}
.rb-right{font-size:.75rem;color:var(--text3);display:flex;align-items:center;gap:6px}
.rb-change{
  color:var(--accent);cursor:pointer;font-weight:500;
  text-decoration:underline;text-decoration-style:dotted;
  font-size:.75rem;
}

/* ── EXPLAINER ── */
.explainer{padding:6rem 4rem;background:var(--bg2);display:grid;grid-template-columns:1fr 1fr;gap:1px;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.exp-half{padding:3.5rem 3rem}
.exp-half:first-child{border-right:1px solid var(--border)}
.exp-tag{font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:1.25rem;display:flex;align-items:center;gap:8px}
.exp-tag::before{content:'';width:20px;height:1px;background:var(--accent)}
.exp-half h3{font-family:'Playfair Display',serif;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;line-height:1.1;letter-spacing:-.02em;margin-bottom:.9rem}
.exp-half p{font-size:.93rem;color:var(--text2);line-height:1.8;margin-bottom:1.25rem}
.exp-example{background:var(--bg3);border:1px solid var(--border);border-left:3px solid var(--accent);padding:1rem 1.2rem;margin-bottom:1.5rem}
.ex-label{font-size:.62rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);margin-bottom:.4rem}
.exp-example p{font-size:.83rem;color:var(--text2);line-height:1.7;margin:0}
.exp-example p em{color:var(--text);font-style:normal;font-weight:500}
.exp-tags{display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.75rem}
.etag{font-size:.68rem;font-weight:600;background:var(--pill-bg);color:var(--pill-text);border:1px solid var(--accent);padding:.22rem .6rem}

/* ── CLUBS ── */
.clubs-sec{padding:6rem 4rem;background:var(--bg)}
.sec-head{text-align:center;margin-bottom:3.5rem}
.sec-eye{font-size:.7rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:.7rem}
.sec-title{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3.5vw,2.7rem);font-weight:900;line-height:1.1;letter-spacing:-.02em}
.sec-sub{font-size:.93rem;color:var(--text2);margin-top:.65rem;max-width:520px;margin-left:auto;margin-right:auto}

/* region switching animation */
.clubs-inner{transition:opacity .25s,transform .25s}
.clubs-inner.switching{opacity:0;transform:translateY(8px)}

.club-tabs{display:flex;justify-content:center;margin-bottom:3rem;border:1px solid var(--border);width:fit-content;margin-left:auto;margin-right:auto;overflow:hidden}
.ctab{display:flex;flex-direction:column;align-items:center;gap:5px;padding:.9rem 1.8rem;cursor:pointer;background:transparent;border:none;border-right:1px solid var(--border);font-family:'Outfit',sans-serif;position:relative;transition:background .2s;min-width:110px}
.ctab:last-child{border-right:none}
.ctab:hover{background:var(--bg3)}
.ctab.on{background:var(--tab-act)}
.ctab.on::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--accent)}
.ctab-icon{width:34px;height:34px;background:var(--surface);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:.95rem;transition:background .2s}
.ctab.on .ctab-icon{background:var(--accent);border-color:var(--accent)}
.ctab-word{font-size:.6rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3)}
.ctab.on .ctab-word{color:var(--accent)}
.ctab-name{font-size:.75rem;font-weight:500;color:var(--text2)}
.ctab.on .ctab-name{color:var(--text)}

.cpanel{display:none}
.cpanel.on{display:grid;grid-template-columns:1.1fr 1fr;gap:3rem;align-items:start}

/* slider */
.strack{overflow:hidden;border:1px solid var(--border);position:relative;height:320px}
.sslides{display:flex;height:100%;transition:transform .45s cubic-bezier(.4,0,.2,1);will-change:transform}
.slide{min-width:100%;width:100%;height:320px;display:flex;align-items:flex-end;padding:1.75rem;position:relative;overflow:hidden;flex-shrink:0}
.slide-bg{position:absolute;inset:0}
.slide-bg{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background-size:cover;background-position:center}
.scap{position:relative;z-index:2;background:rgba(0,0,0,.52);backdrop-filter:blur(8px);padding:.7rem 1rem;border-left:3px solid var(--accent)}
.scap h4{font-size:.9rem;font-weight:600;color:#fff}
.scap p{font-size:.75rem;color:rgba(255,255,255,.68);margin-top:2px}
.sctrl{display:flex;align-items:center;gap:.7rem;margin-top:.65rem}
.sbtn{width:34px;height:34px;background:var(--surface);border:1px solid var(--border);color:var(--text);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.9rem;transition:background .2s}
.sbtn:hover{background:var(--accent);color:var(--bg);border-color:var(--accent)}
.sdots{display:flex;gap:5px;align-items:center}
.dot{width:6px;height:6px;border-radius:50%;background:var(--text3);cursor:pointer;transition:background .2s,transform .2s}
.dot.on{background:var(--accent);transform:scale(1.4)}

.cinfo{padding:.25rem 0}
.cinfo-badge{display:inline-flex;align-items:center;gap:7px;background:var(--pill-bg);color:var(--accent);border:1px solid var(--accent);font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.28rem .75rem;margin-bottom:1.1rem}
.cinfo h3{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:900;line-height:1.1;letter-spacing:-.02em;margin-bottom:.3rem}
.cinfo-tagline{font-size:.85rem;color:var(--accent);font-weight:500;letter-spacing:.04em;margin-bottom:.9rem}
.cinfo-desc{font-size:.9rem;color:var(--text2);line-height:1.8;margin-bottom:1.25rem}
.cfeats{display:flex;flex-direction:column;gap:0;margin-bottom:1.4rem}
.cfeat{display:flex;align-items:flex-start;gap:11px;padding:.7rem 0;border-bottom:1px solid var(--border)}
.cfeat:first-child{border-top:1px solid var(--border)}
.fi{width:26px;height:26px;flex-shrink:0;background:var(--pill-bg);display:flex;align-items:center;justify-content:center;font-size:.8rem}
.ft strong{font-size:.82rem;font-weight:600;display:block}
.ft span{font-size:.78rem;color:var(--text2)}
.cbtns{display:flex;gap:.65rem}
.bsm{padding:.6rem 1.4rem;font-family:'Outfit',sans-serif;font-size:.76rem;font-weight:600;cursor:pointer;letter-spacing:.06em;text-transform:uppercase;transition:opacity .2s,transform .15s}
.bsm:hover{opacity:.84;transform:translateY(-1px)}
.bsm.p{background:var(--accent);color:var(--bg);border:none}
.bsm.g{background:transparent;color:var(--text);border:1px solid var(--border)}
.bsm.g:hover{border-color:var(--accent);color:var(--accent)}

/* ── WHY ── */
.why{padding:6rem 4rem;background:var(--bg2);display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.why h2{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3vw,2.5rem);font-weight:900;line-height:1.1;letter-spacing:-.02em;margin-bottom:1.1rem;margin-top:.75rem}
.why p{font-size:.93rem;color:var(--text2);line-height:1.8;margin-bottom:.9rem}
.why p strong{color:var(--text);font-weight:600}
.why-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);border:1px solid var(--border)}
.wcard{background:var(--bg);padding:1.75rem 1.4rem;transition:background .2s}
.wcard:hover{background:var(--bg3)}
.wcard-icon{width:40px;height:40px;background:var(--pill-bg);display:flex;align-items:center;justify-content:center;font-size:1.1rem;margin-bottom:.65rem}
.wcard h4{font-size:.88rem;font-weight:600;margin-bottom:.3rem}
.wcard p{font-size:.78rem;color:var(--text2);line-height:1.6;margin:0}

/* ── MARKETPLACE ── */
.market{padding:5rem 4rem;background:var(--bg3);display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;border-top:1px solid var(--border)}
.mkt-eye{font-size:.7rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:.7rem}
.mkt-title{font-family:'Playfair Display',serif;font-size:clamp(1.6rem,3vw,2.4rem);font-weight:900;line-height:1.1;letter-spacing:-.02em;margin-bottom:1rem}
.mkt-desc{font-size:.93rem;color:var(--text2);line-height:1.8;margin-bottom:1.5rem}
.mkt-feats{display:flex;flex-direction:column;gap:.5rem}
.mkt-feat{display:flex;align-items:center;gap:10px;font-size:.85rem;color:var(--text2)}
.mkt-feat::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0}
.mkt-visual{background:var(--bg2);border:1px solid var(--border);padding:2.5rem;display:flex;flex-direction:column;align-items:center;min-height:220px;text-align:center;gap:.75rem;justify-content:center}
.dl-badges{display:flex;gap:.65rem;margin-top:.5rem}
.dlb{padding:.45rem 1rem;border:1px solid var(--border);font-size:.72rem;font-weight:600;color:var(--text2)}

/* ── REGIONS ── */
.regions{padding:5rem 4rem;background:var(--bg2);text-align:center}
.rcards{display:flex;gap:1px;background:var(--border);border:1px solid var(--border);max-width:900px;margin:2.5rem auto 0}
.rcard{flex:1;background:var(--bg);padding:2.2rem 1.6rem;text-align:center;transition:background .2s;cursor:pointer}
.rcard:hover{background:var(--bg3)}
.rcard.current{background:var(--tab-act)}
.rflag{font-size:2.2rem;margin-bottom:.65rem}
.rname{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;margin-bottom:.2rem}
.rstatus{font-size:.68rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase}
.rstatus.active{color:var(--accent)}
.rstatus.launching{color:var(--accent2)}
.rstatus.upcoming{color:var(--text3)}
.rline{width:28px;height:2px;background:var(--accent);margin:.65rem auto}
.rdesc{font-size:.78rem;color:var(--text2);line-height:1.6}

/* ── CTA ── */
.cta-sec{padding:6rem 4rem;background:var(--bg);text-align:center;position:relative;overflow:hidden}
.cta-sec::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,var(--pill-bg) 0%,transparent 68%);pointer-events:none}
.cta-sec h2{font-family:'Playfair Display',serif;font-size:clamp(2rem,4vw,3.4rem);font-weight:900;letter-spacing:-.02em;margin-bottom:.9rem;position:relative}
.cta-sec h2 em{font-style:italic;color:var(--accent)}
.cta-sec p{font-size:.98rem;color:var(--text2);max-width:480px;margin:0 auto 2.5rem;position:relative}
.cta-sec .hero-actions{justify-content:center;position:relative}

/* ── FOOTER ── */
footer{background:var(--bg2);border-top:1px solid var(--border);padding:3rem 4rem 2rem}
.footer-top{display:grid;grid-template-columns:1.6fr 1fr 1fr;gap:3rem;padding-bottom:2rem;border-bottom:1px solid var(--border);margin-bottom:2rem}
.fbname{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:900;margin-bottom:.2rem}
.fbsub{font-size:.62rem;color:var(--accent);font-weight:600;letter-spacing:.12em;text-transform:uppercase;margin-bottom:.9rem}
.fbdesc{font-size:.82rem;color:var(--text2);line-height:1.7}
.fcol h5{font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:.9rem}
.fcol a{display:block;text-decoration:none;color:var(--text2);font-size:.82rem;padding:.22rem 0;transition:color .2s}
.fcol a:hover{color:var(--text)}
.fbottom{display:flex;justify-content:space-between;align-items:center;font-size:.76rem;color:var(--text3)}
.furl{color:var(--accent);font-weight:600}

/* ── CLUB LANDING SECTION ── */
.club-landing{background:var(--bg);border-bottom:1px solid var(--border)}

/* compact submenu club tabs — sits directly under nav like a secondary menubar */
/* ── SUB CLUB TAB BAR ── */
.clt-tabs{
  display:flex;align-items:center;background:var(--bg2);
  border-bottom:1px solid var(--border);
  padding:.6rem 4rem;gap:.5rem;overflow-x:auto;
  scrollbar-width:none;
  position:sticky;top:66px;z-index:100;
}
.clt-tabs::-webkit-scrollbar{display:none}
.clt-tab{
  display:flex;align-items:center;gap:7px;
  padding:.55rem 1.3rem;cursor:pointer;
  background:var(--bg3);
  border:1px solid var(--border);
  border-radius:2px;
  font-family:'Outfit',sans-serif;font-size:.8rem;font-weight:500;
  color:var(--text2);white-space:nowrap;
  transition:color .15s,border-color .15s,background .15s,transform .1s;
}
.clt-tab:hover:not(:disabled){color:var(--text);border-color:var(--accent);background:var(--tab-act);transform:translateY(-1px)}
.clt-tab.on{color:var(--accent);border-color:var(--accent);background:var(--tab-act);font-weight:600;box-shadow:0 2px 8px rgba(0,0,0,.15)}
.clt-tab:disabled{opacity:.35;cursor:not-allowed}
.clt-tab-icon{font-size:1rem}
.clt-tab-label{font-size:.8rem}

/* full-width hero slider */
.clt-slider-wrap{position:relative;height:340px;overflow:hidden;background:var(--bg3)}
.clt-slides{display:flex;height:100%;transition:transform .5s cubic-bezier(.4,0,.2,1);will-change:transform}
.clt-slide{min-width:100%;height:340px;position:relative;flex-shrink:0;overflow:hidden}
.clt-slide-bg{position:absolute;inset:0;background-size:cover;background-position:center;display:flex;align-items:center;justify-content:center}
.clt-slide-overlay{position:absolute;inset:0;background:linear-gradient(to right,rgba(0,0,0,.7) 0%,rgba(0,0,0,.2) 60%,transparent 100%)}
.clt-slide-content{position:absolute;bottom:2.5rem;left:4rem;right:40%;z-index:2}
.clt-slide-club{font-size:.62rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:.5rem}
.clt-slide-title{font-family:'Playfair Display',serif;font-size:clamp(1.6rem,3vw,2.4rem);font-weight:900;color:#fff;line-height:1.1;margin-bottom:.4rem}
.clt-slide-sub{font-size:.9rem;color:rgba(255,255,255,.75);line-height:1.5}
.clt-slide-nav{position:absolute;bottom:1.5rem;right:4rem;display:flex;align-items:center;gap:.5rem;z-index:2}
.clt-dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.35);cursor:pointer;transition:background .2s,transform .2s}
.clt-dot.on{background:var(--accent);transform:scale(1.4)}
.clt-arrow{width:36px;height:36px;background:rgba(0,0,0,.4);border:1px solid rgba(255,255,255,.2);color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.9rem;transition:background .2s}
.clt-arrow:hover{background:var(--accent);border-color:var(--accent)}

/* below-slider area: marketing cards OR product listing */
.clt-below{padding:3rem 4rem;background:var(--bg)}

/* marketing overview cards (default view) */
.mkt-overview{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--border);border:1px solid var(--border)}
.mkt-card{
  background:var(--bg);padding:1.5rem 1.2rem;text-align:center;
  cursor:pointer;transition:background .2s,transform .15s;
  display:flex;flex-direction:column;align-items:center;gap:.5rem;
  position:relative;
}
.mkt-card:hover{background:var(--bg3)}
.mkt-card:hover .mkt-card-arrow{opacity:1;transform:translateX(3px)}
.mkt-card.active{background:var(--tab-act);border-bottom:2px solid var(--accent)}
.mkt-card-img{width:48px;height:48px;border-radius:50%;background:var(--surface);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1.4rem;transition:background .2s,border-color .2s}
.mkt-card:hover .mkt-card-img{border-color:var(--accent)}
.mkt-card.active .mkt-card-img{background:var(--accent);border-color:var(--accent)}
.mkt-card-name{font-size:.68rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text2)}
.mkt-card.active .mkt-card-name{color:var(--accent)}
.mkt-card-pitch{font-size:.75rem;color:var(--text3);line-height:1.5}
.mkt-card-arrow{font-size:.8rem;color:var(--accent);opacity:0;transition:opacity .2s,transform .2s;margin-top:.2rem}

/* product listing view */
.prod-listing{display:none}
.prod-listing.on{display:block}
.prod-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:1.5rem;padding-bottom:1rem;
  border-bottom:1px solid var(--border);
  flex-wrap:wrap;gap:.75rem;
}
.prod-header-left{display:flex;align-items:center;gap:12px}
.prod-club-icon{width:40px;height:40px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
.prod-header h3{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:900;margin:0}
.prod-header-sub{font-size:.72rem;color:var(--text3);margin-top:2px}
.prod-back{background:transparent;border:1px solid var(--border);color:var(--text2);padding:.38rem .9rem;font-family:'Outfit',sans-serif;font-size:.73rem;cursor:pointer;transition:border-color .2s,color .2s;white-space:nowrap}
.prod-back:hover{border-color:var(--accent);color:var(--accent)}
.prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.9rem}
.prod-card{
  background:var(--surface);border:1px solid var(--border);
  padding:1.2rem;display:flex;flex-direction:column;gap:.4rem;
  transition:border-color .2s,transform .15s;
}
.prod-card:hover{border-color:var(--accent);transform:translateY(-2px)}
.prod-card-tag{font-size:.58rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--accent)}
.prod-card-name{font-size:.92rem;font-weight:600;color:var(--text);line-height:1.3}
.prod-card-desc{font-size:.78rem;color:var(--text2);line-height:1.6;flex:1}
.prod-card-badges{display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.3rem}
.prod-badge{font-size:.58rem;font-weight:600;padding:.18rem .5rem;border:1px solid var(--border);color:var(--text3);letter-spacing:.06em;text-transform:uppercase}
.prod-card-footer{display:flex;align-items:center;justify-content:space-between;margin-top:.7rem;padding-top:.7rem;border-top:1px solid var(--border)}
.prod-card-price{font-size:1.05rem;font-weight:700;color:var(--text)}
.prod-card-price.free{color:var(--accent)}
.prod-enroll{padding:.42rem 1rem;font-family:'Outfit',sans-serif;font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;cursor:pointer;transition:opacity .2s,transform .15s;border:none}
.prod-enroll.paid{background:var(--accent);color:var(--bg)}
.prod-enroll.free-btn{background:transparent;color:var(--accent);border:1px solid var(--accent)}
.prod-enroll:hover{opacity:.82;transform:translateY(-1px)}
.prod-loading{text-align:center;padding:3rem 2rem;color:var(--text3);font-size:.85rem;line-height:1.8}

/* ── AUTH MODAL ── */
.modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,.65);
  z-index:500;display:none;align-items:center;justify-content:center;
  backdrop-filter:blur(4px);
}
.modal-overlay.open{display:flex}
.modal-box{
  background:var(--bg2);border:1px solid var(--border);
  width:100%;max-width:420px;padding:2rem;position:relative;
}
.modal-close{
  position:absolute;top:.75rem;right:.75rem;
  background:transparent;border:none;color:var(--text3);
  font-size:1.2rem;cursor:pointer;line-height:1;
}
.modal-close:hover{color:var(--text)}
.modal-title{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:900;margin-bottom:1.5rem}
.modal-tabs{display:flex;gap:0;margin-bottom:1.5rem;border:1px solid var(--border)}
.modal-tab{
  flex:1;padding:.5rem;text-align:center;cursor:pointer;
  font-size:.78rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;
  background:transparent;border:none;color:var(--text3);
  font-family:'Outfit',sans-serif;transition:background .2s,color .2s;
}
.modal-tab.on{background:var(--accent);color:var(--bg)}
.modal-form{display:flex;flex-direction:column;gap:.85rem}
.modal-form input{
  width:100%;padding:.65rem .9rem;
  background:var(--bg3);border:1px solid var(--border);
  color:var(--text);font-family:'Outfit',sans-serif;font-size:.85rem;
  outline:none;transition:border-color .2s;
}
.modal-form input:focus{border-color:var(--accent)}
.modal-form input::placeholder{color:var(--text3)}
.modal-btn{
  background:var(--accent);color:var(--bg);border:none;
  padding:.75rem;font-family:'Outfit',sans-serif;
  font-size:.85rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
  cursor:pointer;transition:opacity .2s;margin-top:.3rem;
}
.modal-btn:hover{opacity:.85}
.modal-btn:disabled{opacity:.5;cursor:not-allowed}
.modal-msg{font-size:.78rem;min-height:1.2rem;text-align:center;margin-top:.3rem}
.modal-msg.ok{color:var(--accent)}
.modal-msg.err{color:#e63946}
.modal-divider{font-size:.72rem;color:var(--text3);text-align:center;margin:.3rem 0}

/* ── ADD PRODUCT MODAL ── */
.prod-modal-box{max-width:520px}
.modal-form select{
  width:100%;padding:.65rem .9rem;
  background:var(--bg3);border:1px solid var(--border);
  color:var(--text);font-family:'Outfit',sans-serif;font-size:.85rem;
  outline:none;transition:border-color .2s;
}
.modal-form select:focus{border-color:var(--accent)}
.modal-form textarea{
  width:100%;padding:.65rem .9rem;resize:vertical;min-height:80px;
  background:var(--bg3);border:1px solid var(--border);
  color:var(--text);font-family:'Outfit',sans-serif;font-size:.85rem;
  outline:none;transition:border-color .2s;
}
.modal-form textarea:focus{border-color:var(--accent)}
.modal-form label{font-size:.72rem;color:var(--text3);letter-spacing:.06em;text-transform:uppercase;margin-bottom:-.4rem}

/* ── NAV USER STATE ── */
.nav-user{display:flex;align-items:center;gap:.6rem}
.nav-user-name{font-size:.75rem;color:var(--accent);font-weight:600;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.nav-signout{background:transparent;border:1px solid var(--border);color:var(--text2);padding:.38rem .75rem;font-family:'Outfit',sans-serif;font-size:.72rem;cursor:pointer;transition:border-color .2s,color .2s}
.nav-signout:hover{border-color:var(--accent);color:var(--accent)}

/* ── ADD PRODUCT BTN in prod header ── */
.prod-add-btn{
  background:transparent;border:1px solid var(--accent);color:var(--accent);
  padding:.38rem .9rem;font-family:'Outfit',sans-serif;font-size:.72rem;
  font-weight:600;letter-spacing:.06em;text-transform:uppercase;cursor:pointer;
  transition:background .2s,color .2s;
}
.prod-add-btn:hover{background:var(--accent);color:var(--bg)}

@keyframes shimmer{0%,100%{opacity:.4}50%{opacity:.8}}

@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
.hero-badge{animation:fadeUp .5s ease both}
.hero h1  {animation:fadeUp .5s .1s ease both}
.hero-hook{animation:fadeUp .5s .2s ease both}
.dual-mode{animation:fadeUp .5s .3s ease both}
.hero-actions{animation:fadeUp .5s .4s ease both}

/* ── ROUTES SECTION ── */
.routes-sec{padding:5rem 4rem;background:var(--bg2);text-align:center}
.routes-sec .sec-sub{margin-bottom:2.5rem}

/* Route grid */
.route-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
  gap:1px;background:var(--border);
  border:1px solid var(--border);
  max-width:1100px;margin:0 auto 0;
  text-align:left;
}
.route-card{
  background:var(--bg);padding:1.6rem 1.4rem;
  cursor:pointer;transition:background .2s,transform .15s;
  display:flex;flex-direction:column;gap:.5rem;
  position:relative;overflow:hidden;
}
.route-card::before{
  content:'';position:absolute;top:0;left:0;
  width:3px;height:100%;background:var(--accent);
  transform:scaleY(0);transform-origin:top;
  transition:transform .2s;
}
.route-card:hover{background:var(--bg3);transform:translateY(-2px)}
.route-card:hover::before{transform:scaleY(1)}
.route-card.selected{background:var(--tab-act)}
.route-card.selected::before{transform:scaleY(1)}
.rc-icon{font-size:1.6rem;margin-bottom:.2rem}
.rc-name{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;color:var(--text)}
.rc-desc{font-size:.78rem;color:var(--text2);line-height:1.6}
.rc-meta{display:flex;align-items:center;gap:.5rem;margin-top:.3rem;flex-wrap:wrap}
.rc-badge{
  font-size:.6rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
  padding:.18rem .55rem;border:1px solid var(--accent);
  color:var(--accent);background:var(--pill-bg);
}
.rc-wpt-count{font-size:.7rem;color:var(--text3)}
.rc-arrow{
  margin-top:auto;align-self:flex-end;
  font-size:.75rem;color:var(--accent);
  opacity:0;transition:opacity .2s;
}
.route-card:hover .rc-arrow,.route-card.selected .rc-arrow{opacity:1}

/* Route map panel */
.route-map-panel{
  max-width:1100px;margin:2rem auto 0;
  border:1px solid var(--border);
  background:var(--bg);
  animation:fadeUp .3s ease;
}
.rmp-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:1rem 1.4rem;border-bottom:1px solid var(--border);
  flex-wrap:wrap;gap:.75rem;
}
.rmp-header-left{display:flex;align-items:center;gap:1rem}
.rmp-back{
  background:transparent;border:1px solid var(--border);
  color:var(--text2);padding:.38rem .85rem;
  font-family:'Outfit',sans-serif;font-size:.75rem;
  cursor:pointer;transition:border-color .2s,color .2s;white-space:nowrap;
}
.rmp-back:hover{border-color:var(--accent);color:var(--accent)}
.rmp-route-name{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:900;color:var(--text)}
.rmp-route-sub{font-size:.72rem;color:var(--text3);margin-top:2px}
.rmp-body{
  display:grid;grid-template-columns:1fr 280px;
  min-height:420px;
}
.rmp-map-wrap{
  position:relative;border-right:1px solid var(--border);
  min-height:420px;
}
.rmp-map-loading{
  position:absolute;inset:0;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:var(--bg3);
}
.rmp-wpts{padding:1.2rem;overflow-y:auto;max-height:420px}
.rmp-wpts-title{
  font-size:.65rem;font-weight:700;letter-spacing:.12em;
  text-transform:uppercase;color:var(--accent);margin-bottom:.9rem;
}
.rmp-wpts-list{display:flex;flex-direction:column;gap:0}
.rmp-wpt-item{
  display:flex;align-items:flex-start;gap:.75rem;
  padding:.65rem 0;border-bottom:1px solid var(--border);
  position:relative;
}
.rmp-wpt-item:last-child{border-bottom:none}
.rmp-wpt-num{
  width:22px;height:22px;border-radius:50%;
  background:var(--accent);color:var(--bg);
  display:flex;align-items:center;justify-content:center;
  font-size:.6rem;font-weight:800;flex-shrink:0;margin-top:1px;
}
.rmp-wpt-info{}
.rmp-wpt-name{font-size:.82rem;font-weight:600;color:var(--text)}
.rmp-wpt-coord{font-size:.65rem;font-family:monospace;color:var(--text3);margin-top:1px}

/* Leaflet overrides for theme */
.leaflet-container{background:var(--bg2)!important}
.leaflet-tile{filter:brightness(.85) saturate(.7)}
[data-theme="fresh"] .leaflet-tile{filter:none}

@media(max-width:960px){
  nav{padding:0 1.2rem}.nav-links{display:none}
  .hero,.clubs-sec,.why,.market,.routes-sec,.cta-sec,.explainer,footer,.region-bar{padding-left:1.5rem;padding-right:1.5rem}
  .rmp-body{grid-template-columns:1fr}
  .rmp-map-wrap{min-height:280px;border-right:none;border-bottom:1px solid var(--border)}
  .route-grid{grid-template-columns:1fr}
  .explainer{grid-template-columns:1fr}
  .exp-half:first-child{border-right:none;border-bottom:1px solid var(--border)}
  .cpanel.on{grid-template-columns:1fr}
  .club-tabs{overflow-x:auto;max-width:100%}
  .why{grid-template-columns:1fr}
  .market{grid-template-columns:1fr}
  .rcards{flex-direction:column}
  .footer-top{grid-template-columns:1fr;gap:2rem}
  .fbottom{flex-direction:column;gap:.5rem;text-align:center}
  .clt-tabs{padding:0 1rem}
  .clt-below{padding:2rem 1.5rem}
  .mkt-overview{grid-template-columns:repeat(2,1fr)}
  .clt-slide-content{left:1.5rem;right:1.5rem}
  .clt-slide-nav{right:1.5rem}
  .prod-grid{grid-template-columns:1fr}
}
</style>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
</head>
<body data-theme="dark">

<div class="lbar" id="lbar"></div>

<!-- NAV -->
<nav>
  <div style="display:flex;align-items:center;gap:10px">
    <a class="nav-brand" href="#" style="text-decoration:none">
      <div class="nav-logo">A</div>
    </a>
    <div style="width:1px;height:28px;background:var(--border)"></div>
    <div class="region-selector" id="regionSelector">
      <button class="region-btn" id="regionBtn" onclick="toggleRegionDropdown()">
        <span class="rflag" id="btnFlag">🌐</span>
        <span class="rname" id="btnName">Loading...</span>
        <span class="chevron">▼</span>
      </button>
      <div class="region-dropdown" id="regionDropdown">
        <div class="ip-notice">Showing clubs available in your region</div>
      </div>
    </div>
  </div>

  <div class="nav-links">
    <a href="#explainer">How It Works</a>
    <a href="#why">Why Us</a>
    <a href="#marketplace" class="highlight">Marketplace</a>
    <a href="#routes">Routes</a>
  </div>

  <div class="nav-right">
    <div class="theme-switcher">
      <div class="tbtn on" data-t="dark"  onclick="setTheme('dark',this)"  title="Professional Dark"></div>
      <div class="tbtn"    data-t="fresh" onclick="setTheme('fresh',this)" title="Fresh Modern"></div>
      <div class="tbtn"    data-t="bold"  onclick="setTheme('bold',this)"  title="Bold Minimal"></div>
    </div>
    <button class="nav-cta" id="navAuthBtn" onclick="openAuthModal()">Join Now</button>
    <div class="nav-user" id="navUser" style="display:none">
      <span class="nav-user-name" id="navUserName"></span>
      <button class="nav-signout" onclick="signOut()">Sign Out</button>
    </div>
  </div>
</nav>

<!-- ══ CLUB LANDING ══ -->
<section class="club-landing" id="clubLanding">

  <!-- Club Tabs Bar -->
  <div class="clt-tabs" id="cltTabs">
    <div class="skel" style="width:600px;height:46px;margin:.5rem 0"></div>
  </div>

  <!-- Hero Slider (full width, club-specific) -->
  <div class="clt-slider-wrap" id="cltSliderWrap">
    <div class="clt-slides" id="cltSlides">
      <div class="clt-slide">
        <div class="clt-slide-bg" style="background:linear-gradient(135deg,var(--bg3),var(--bg));display:flex;align-items:center;justify-content:center"><span style="font-size:5rem;opacity:.3">🏛️</span></div>
        <div class="clt-slide-overlay"></div>
